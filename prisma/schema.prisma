generator client {
  provider      = "prisma-client-js" // Gerador de cliente Prisma para Node.js
  binaryTargets = ["native", "windows"] // Compilação nativa e para Windows
}

datasource db {
  provider = "postgresql" // provedor de banco de dados PostgreSQL
  url      = env("DATABASE_URL") // URL de conexão com o banco de dados PostgreSQL vindo do .env
}

model User {
  id Int @id @default(autoincrement()) // ID único do usuário
  name String // Nome do usuário
  email String @unique // Email único
  password String // Senha do usuário
  createdAt DateTime @default(now()) // Data de criação do usuário
  updatedAt DateTime @updatedAt // Data de atualização do usuário
  role Role @default(user) // Tipo de usuário, padrão "user"
  tenantId  String  @db.Uuid @unique // ID do tenant do usuário, único por usuário
  active Boolean @default(false) // Se o usuário está ativo ou não

 }

enum Role {
  user
  admin
}