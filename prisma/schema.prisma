generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// TENANT (Food Truck)
// ─────────────────────────────────────────
model Tenant {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  logoUrl     String?
  phone       String?
  deliveryFee Decimal  @default(0) @db.Decimal(10, 2)
  ownerId     Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  zipCode     String?
  street      String?
  number      String?
  complement  String?
  district    String?
  city        String?
  state       String?
  country     String?
  email       String?
  website     String?
  instagram   String?
  facebook    String?
  twitter     String?
  youtube     String?
  geoLocation String?

  // Relacionamentos
  owner           User                  @relation(fields: [ownerId], references: [id])
  media           TenantMedia[]
  openingHours    TenantOpeningHour[]
  paymentMethods  TenantPaymentMethod[]
  deliveryDrivers DeliveryDriver[]
  deliveryMen     deliveryMen[]
  categories      Category[]
  products        Product[]
  orders          Order[]
  tables          Table[]
}

model TenantOpeningHour {
  id        Int      @id @default(autoincrement())
  tenantId  String   @db.Uuid
  weekday   Weekday
  closed    Boolean  @default(false)
  openTime  String?
  closeTime String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, weekday])
  @@index([tenantId])
}

model TenantPaymentMethod {
  id        Int               @id @default(autoincrement())
  tenantId  String            @db.Uuid
  type      PaymentMethodType
  enabled   Boolean           @default(true)
  label     String?
  details   Json?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type])
  @@index([tenantId])
}

model DeliveryDriver {
  id        Int      @id @default(autoincrement())
  tenantId  String   @db.Uuid
  name      String
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantMedia {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  kind      String
  url       String
  mimeType  String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// ─────────────────────────────────────────
// USUÁRIO
// ─────────────────────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(user)
  active    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenants Tenant[]
  orders  Order[]
}

// ─────────────────────────────────────────
// CATEGORIA DO CARDÁPIO
// ─────────────────────────────────────────
model Category {
  id        Int      @id @default(autoincrement())
  name      String
  tenantId  String   @db.Uuid
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]
}

// ─────────────────────────────────────────
// PRODUTO
// ─────────────────────────────────────────
model Product {
  id          Int      @id @default(autoincrement())
  seq         Int
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  active      Boolean  @default(true)
  tenantId    String   @db.Uuid
  categoryId  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  category     Category      @relation(fields: [categoryId], references: [id])
  orderItems   OrderItem[]
  optionGroups OptionGroup[]

  @@unique([tenantId, seq])
}

// ─────────────────────────────────────────
// GRUPO DE OPÇÕES (ex: "Ponto da Carne", "Tamanho", "Borda")
// ─────────────────────────────────────────
model OptionGroup {
  id        Int     @id @default(autoincrement())
  name      String
  required  Boolean @default(false)
  multiple  Boolean @default(false)
  min       Int     @default(0)
  max       Int     @default(1)
  productId Int

  product Product  @relation(fields: [productId], references: [id])
  options Option[]
}

// ─────────────────────────────────────────
// OPÇÃO (ex: "Bem passado", "Bacon +R$3", "Borda Recheada")
// ─────────────────────────────────────────
model Option {
  id            Int     @id @default(autoincrement())
  name          String
  priceModifier Decimal @default(0) @db.Decimal(10, 2)
  groupId       Int

  group            OptionGroup       @relation(fields: [groupId], references: [id])
  orderItemOptions OrderItemOption[]
}

// ─────────────────────────────────────────
// MESA (pedidos presenciais)
// ─────────────────────────────────────────
model Table {
  id       Int    @id @default(autoincrement())
  number   Int
  tenantId String @db.Uuid

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  orders Order[]

  @@unique([tenantId, number])
}

// ─────────────────────────────────────────
// PEDIDO
// ─────────────────────────────────────────
model Order {
  id              Int         @id @default(autoincrement())
  tenantId        String      @db.Uuid
  userId          Int?
  tableId         Int?
  type            OrderType
  status          OrderStatus @default(pending)
  statusChangedAt DateTime    @default(now())
  total           Decimal     @db.Decimal(10, 2)
  deliveryFee     Decimal     @default(0) @db.Decimal(10, 2)
  deliveryManId   Int?
  notes           String?
  customerName    String?
  customerPhone   String?
  customerAddress String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  table       Table?       @relation(fields: [tableId], references: [id])
  deliveryMan deliveryMen? @relation(fields: [deliveryManId], references: [id])
  items       OrderItem[]
}

// ─────────────────────────────────────────
// ITEM DO PEDIDO
// ─────────────────────────────────────────
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  notes     String?

  order   Order             @relation(fields: [orderId], references: [id])
  product Product           @relation(fields: [productId], references: [id])
  options OrderItemOption[]
}

// ─────────────────────────────────────────
// OPÇÕES ESCOLHIDAS NO ITEM
// ─────────────────────────────────────────
model OrderItemOption {
  id          Int     @id @default(autoincrement())
  orderItemId Int
  optionId    Int
  quantity    Int     @default(1)
  priceAdded  Decimal @db.Decimal(10, 2)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  option    Option    @relation(fields: [optionId], references: [id])
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────
enum Role {
  user
  admin
  tenant
}

enum OrderType {
  local // consumir no local
  delivery // entrega
  pickup // retirada no local
}

enum OrderStatus {
  pending // pendente
  confirmed // confirmado
  preparing // preparando
  ready // pronto
  out_for_delivery // em entrega
  delivered // entregue
  cancelled // cancelado  // entreg
  returned //  devolvido
}

enum Weekday {
  mon
  tue
  wed
  thu
  fri
  sat
  sun
}

enum PaymentMethodType {
  cash
  pix
  debit_card
  credit_card
  voucher
  other
}

// ─────────────────────────────────────────
// ENTREGADORES
// ─────────────────────────────────────────
model deliveryMen {
  id           Int     @id @default(autoincrement())
  name         String
  phone        String
  email        String?
  address      String
  plateVehicle String // placa do veiculo
  modelvehicle String // modelo do veiculo
  avatar       String?
  // relação com o Tenant
  tenantId     String  @db.Uuid
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([tenantId])
}
